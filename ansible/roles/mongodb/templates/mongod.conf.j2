# {{ ansible_managed }}
# mongod.conf – MongoDB {{ mongodb_version }}

systemLog:
  destination: file
  logAppend: true
  path: {{ mongodb_log_dir }}/mongod.log

storage:
  dbPath: {{ mongodb_data_dir }}
  journal:
    enabled: true

processManagement:
  fork: true
  pidFilePath: /var/run/mongodb/mongod.pid
  timeZoneInfo: /usr/share/zoneinfo

net:
  port: {{ mongodb_port }}
  bindIp: {{ mongodb_bind_ip }}

security:
  authorization: enabled
