# ansible/vault/vault_secrets.yml.example
# ───────────────────────────────────────────────────────────
# Copy this to vault_secrets.yml and fill in real passwords,
# then encrypt with: ansible-vault encrypt vault_secrets.yml
# ───────────────────────────────────────────────────────────
---
vault_glassfish_admin_password: "CHANGE_ME"
vault_mongodb_admin_password: "CHANGE_ME"
vault_mongodb_app_password: "changeme"
vault_jenkins_admin_password: "CHANGE_ME"